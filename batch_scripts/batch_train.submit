executable = batch_train.sh

# adjust arguments as needed....
arguments = "config/ml_GNN_LQ.yaml config/user_Holly.yaml"

getenv = true
output = ../logs/batch_train_$(ClusterID).out
error = ../logs/batch_train_$(ClusterID).err
log = ../logs/batch_train_$(ClusterID).log
request_gpus = 1
batch_name = "train"

require_gpus = (Capability >= 9.0) && (GlobalMemoryMb >= 90000)
request_memory = 90000
queue 1

