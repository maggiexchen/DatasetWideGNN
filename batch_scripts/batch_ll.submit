executable = batch_ll.sh

# adjust arguments as needed....

#arguments = "10000 euclidean LQ_HL_bestCos"
#arguments = "10000 euclidean LQ_HL_bestEuc"

getenv = true
output = ../logs/batch_ll_$(ClusterID).out
error = ../logs/batch_ll_$(ClusterID).err
log = ../logs/batch_ll_$(ClusterID).log
batch_name = "calcLL"

request_memory = 15000
queue 1

